@model VasosInteligentes.Models.Vaso

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Vaso</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <div class="form-group">
                <label asp-for="Nome" class="control-label"></label>
                <input asp-for="Nome" class="form-control" />
                <span asp-validation-for="Nome" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="PlantaId" class="control-label"></label>
                <select asp-for="PlantaId" class="form-control" asp-items="ViewBag.PlantaId"> 
                </select>
                <span asp-validation-for="PlantaId" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Localizacao" class="control-label"></label>
                <input asp-for="Localizacao" class="form-control" />
                <span asp-validation-for="Localizacao" class="text-danger"></span>
            </div>
            <div class="form-group d-flex mt-4 gap-2">
                <input type="submit" value="Salvar" class="btn btn-primary w-100" />
                <a class="btn btn-secondary w-100" asp-action="Index"> Voltar para lista</a>
            </div>
        </form>
    </div>
</div>


@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
