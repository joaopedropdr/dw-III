@model IEnumerable<exercicio_preparatorio.Models.Clinica>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create" asp-controller="Clinica">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Nome)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Alarme)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.Nome)
                </td>
                <td class="gap-3">
                    @*Sintaxe do ? -> verificação ? caso-verdadeiro : caso-falso *@
                    <a class="btn @(item.Alarme ? "btn-danger" : "btn-success")"
                           asp-action="@(item.Alarme ? "DesativarAlarme" : "AtivarAlarme")"
                           asp-route-id="@item.Id">
                        @(item.Alarme ? "Desativar alarme" : "Ativar alarme")
                    </a>
                    <a class="btn btn-outline-primary " asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                    <a class="btn btn-outline-danger"asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                </td>
                <td>

                </td>
            </tr>
        }
    </tbody>
</table>